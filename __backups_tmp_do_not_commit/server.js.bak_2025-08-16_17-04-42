/* === Dash Session-Login (auto-insert) === */
const crypto = require('crypto');
const DASH_USER   = process.env.DASH_USER   || 'admin';
const DASH_PASS   = process.env.DASH_PASS   || 'Rottweil.12';
const DASH_SECRET = process.env.DASH_SECRET || 'change_me';

function sign(s){ return crypto.createHmac('sha256', DASH_SECRET).update(s).digest('hex'); }
function getCookie(req,name){
  const c = req.headers.cookie||''; const m = c.match(new RegExp('(?:^|; )'+name+'=([^;]+)'));
  return m ? decodeURIComponent(m[1]) : null;
}
function hasSession(req){
  try{
    const raw = getCookie(req,'dash_session'); if(!raw) return false;
    const [user,exp,mac] = Buffer.from(raw,'base64').toString('utf8').split('|');
    if(!user || !exp || !mac) return false;
    if(Date.now() > Number(exp)) return false;
    return mac === sign(user+'|'+exp);
  }catch{ return false; }
}
function requireDashSession(req,res,next){
  if(hasSession(req)) return next();
  res.set('Cache-Control','no-store, no-cache, must-revalidate').status(401);
  return res.sendFile(path.join(__dirname,'public','dash-login.html'));
}

// Login/Logout
app.post('/dash-login', express.urlencoded({extended:true}), (req,res)=>{
  const { username, password } = req.body || {};
  if(username===DASH_USER && password===DASH_PASS){
    const exp = Date.now() + 60*1000; // 60s gültig
    const val = Buffer.from(DASH_USER+'|'+exp+'|'+sign(DASH_USER+'|'+exp)).toString('base64');
    res.setHeader('Set-Cookie', 'dash_session='+encodeURIComponent(val)+'; HttpOnly; Path=/; Max-Age=60; SameSite=Lax');
    return res.redirect('/index.html');
  }
  res.status(401).send('Login fehlgeschlagen');
});

app.get('/dash-logout', (_req,res)=>{
  res.setHeader('Set-Cookie','dash_session=; Max-Age=0; Path=/; HttpOnly; SameSite=Lax');
  res.redirect('/dash-login');
});

