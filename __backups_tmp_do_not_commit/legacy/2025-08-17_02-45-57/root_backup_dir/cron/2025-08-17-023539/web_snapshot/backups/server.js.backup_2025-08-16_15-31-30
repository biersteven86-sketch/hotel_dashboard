require("dotenv").config();
const express = require("express");
const path    = require("path");
const app     = express();
const PORT    = process.env.PORT || 3011;

app.disable("x-powered-by");
app.set("trust proxy", true);
app.use(express.urlencoded({ extended: true }));
app.use(express.json());

// Statisch aus ./public, aber ohne Auto-Index
app.use(express.static(path.join(__dirname, "public"), { index: false }));

// Root -> /login
app.get("/", (_req, res) => res.redirect(302, "/login"));

// Login-Form (liefert public/login.html)
app.get("/login", (_req, res) => {
  res.sendFile(path.join(__dirname, "public", "login.html"));
});

// DUMMY-LOGIN: akzeptiert jeden POST und leitet IMMER auf /ibelsa.html
app.post("/login", (req, res) => {
  console.log("[DummyLogin] body=", req.body);
  return res.redirect(303, "/ibelsa.html");
});

// 404-Fallback
app.use((_req, res) => res.status(404).send("Not Found"));

// Nur auf Loopback hören
app.listen(PORT, "127.0.0.1", () => {
  console.log("Hotel Dashboard läuft auf Port", PORT);
});
