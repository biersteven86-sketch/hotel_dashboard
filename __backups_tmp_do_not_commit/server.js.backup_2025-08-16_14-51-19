require("dotenv").config();
const express = require("express");
const session = require("express-session");
const path    = require("path");
const app     = express();

const PORT   = process.env.PORT || 3011;
const isProd = process.env.NODE_ENV === "production";

app.disable("x-powered-by");
app.set("trust proxy", true);
app.use(express.urlencoded({ extended: true }));
app.use(express.json());

// --- Sessions ---------------------------------------------------------------
app.use(session({
  name: "hd.sid",
  secret: process.env.SESSION_SECRET || "replace-me-in-.env",
  resave: false,
  saveUninitialized: false,
  cookie: {
    httpOnly: true,
    sameSite: "lax",
    secure: isProd,                 // in PROD (https über Apache) sicher, lokal über http erlaubt
    maxAge: 60 * 60 * 1000          // 1h
  }
}));

// Hilfs-Middleware für geschützte Seiten
function requireAuth(req, res, next) {
  if (req.session && req.session.auth === true) return next();
  return res.redirect(302, "/login");
}

// --- Routen (Reihenfolge ist wichtig!) --------------------------------------

// Healthcheck
app.get("/healthz", (_req, res) => res.json({ ok: true }));

// Root -> Login
app.get("/", (_req, res) => res.redirect(302, "/login"));

// Login-Form
app.get("/login", (_req, res) => {
  res.sendFile(path.join(__dirname, "public", "login.html"));
});

// Login-POST: einfache Prüfung (nur „nicht leer“), dann Session setzen
app.post("/login", (req, res) => {
  const { username, password } = req.body || {};
  if (!username || !password) return res.redirect(302, "/login");
  req.session.auth = true;
  return res.redirect(303, "/ibelsa.html");
});

// Logout
app.get("/logout", (req, res) => {
  try { req.session.destroy(() => res.redirect(302, "/login")); }
  catch { res.redirect(302, "/login"); }
});

// Geschützte Seite: /ibelsa.html nur mit Session
app.get(["/ibelsa", "/ibelsa.html"], requireAuth, (_req, res) => {
  res.sendFile(path.join(__dirname, "public", "ibelsa.html"));
});

// Statische Dateien (nach den obigen Routen, damit /ibelsa.html nicht ungeprüft rausgeht)
app.use(express.static(path.join(__dirname, "public"), { index: false }));

// 404-Fallback
app.use((_req, res) => res.status(404).send("Not Found"));

app.listen(PORT, "127.0.0.1", () => {
  console.log("Hotel Dashboard läuft auf Port", PORT);
});
