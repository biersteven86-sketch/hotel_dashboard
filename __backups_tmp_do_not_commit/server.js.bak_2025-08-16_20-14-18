const express = require('express');
const path = require('path');
const fs = require('fs');

const PORT = process.env.PORT || 3011;
const WEB  = __dirname;
const PUB  = path.join(WEB, 'public');

const app = express();
app.disable('x-powered-by');
app.set('trust proxy', true);
app.use(express.urlencoded({ extended: true }));
app.use(express.json());

function loadUsers() {
  try {
    const raw = fs.readFileSync(path.join(WEB, 'users.json'), 'utf8');
    const list = JSON.parse(raw);
    return Array.isArray(list) ? list : list.users || [];
  } catch {
    return [];
  }
}

// Startseite => Login
app.get('/', (_req, res) => res.redirect(302, '/login.html'));

// Login-Form anzeigen
app.get('/login', (_req, res) => res.sendFile(path.join(PUB, 'login.html')));

// Login verarbeiten
app.post('/login', (req, res) => {
  const { username, password } = req.body || {};
  const users = loadUsers();
  const user = users.find(u => String(u.username) === String(username) &&
                               String(u.password) === String(password));
  if (!user) {
    return res.status(401).send('Ungültige Zugangsdaten');
  }
  // Ziel je nach Benutzer
  if (String(user.username).toLowerCase() === 'admin') {
    return res.redirect(302, '/status.html');
  }
  return res.redirect(302, '/ibelsa.html');
});

// Statische Dateien (muss NACH den Routen kommen)
app.use(express.static(PUB, { index: false }));

app.listen(PORT, () => {
  console.log(`Hotel Dashboard läuft auf Port ${PORT}`);
});
