/* --- kleine Helfer --- */
const sendFile = p => path.join(__dirname,"public",p);
const parseCookies = (req)=>{
  const h=req.headers.cookie||""; const out={};
  h.split(";").map(v=>v.trim()).filter(Boolean).forEach(kv=>{
    const i=kv.indexOf("="); if(i>0) out[kv.slice(0,i)]=decodeURIComponent(kv.slice(i+1));
  });
  return out;
};
const setCookie = (res, name, val, opts={})=>{
  const parts = [`${name}=${encodeURIComponent(val)}`, "Path=/", "HttpOnly", "SameSite=Lax"];
  if (opts.maxAge) parts.push(`Max-Age=${opts.maxAge}`);
  if (opts.secure) parts.push("Secure");
  res.setHeader("Set-Cookie", parts.join("; "));
};

/* --- Credentials aus ENV --- */
const DASH_USER   = process.env.DASH_USER   || "admin";
const DASH_PASS   = process.env.DASH_PASS   || "Rottweil.12";
const IBELSA_USER = process.env.IBELSA_USER || "info@myhome-rottweil.de";
const IBELSA_PASS = process.env.IBELSA_PASS || "Rottweil.12";

/* --- Guards --- */
/* Status: 10 Minuten Auto-Timeout (Cookie mit Max-Age=600) */
function requireDash(req,res,next){
  const c = parseCookies(req);
  if (c.dash_sid === "ok") return next();
  res.status(401).sendFile(sendFile("login.html"));
}
/* Ibelsa: kein Auto-Timeout (Session-Cookie) – Logout möglich */
function requireIbelsa(req,res,next){
  const c = parseCookies(req);
  if (c.ibelsa_sid === "ok") return next();
  res.status(401).sendFile(sendFile("login.html"));
}

/* --- Statisch ausliefern --- */
