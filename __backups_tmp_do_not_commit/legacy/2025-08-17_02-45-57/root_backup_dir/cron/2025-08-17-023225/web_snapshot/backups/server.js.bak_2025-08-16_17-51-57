/* Login-POST: entscheidet anhand Benutzer, wohin es geht */
app.post("/login", (req,res)=>{
  const { username="", password="", target="" } = req.body || {};
  // Admin -> Status-Dashboard
  if (username===DASH_USER && password===DASH_PASS) {
    setCookie(res,"dash_sid","ok",{ maxAge:600, secure:false }); // 10 Min
    return res.redirect(302,"/status.html");
  }
  // Business -> Ibelsa
  if (username===IBELSA_USER && password===IBELSA_PASS) {
    setCookie(res,"ibelsa_sid","ok",{ /* kein Max-Age = bis Logout/Browserende */ secure:false });
    return res.redirect(302,"/ibelsa.html");
  }
  // optional: explizites Zielfeld (falls mehrere Logins)
  if (target==="status" && password===DASH_PASS) {
    setCookie(res,"dash_sid","ok",{ maxAge:600, secure:false });
    return res.redirect(302,"/status.html");
  }
  if (target==="ibelsa" && password===IBELSA_PASS) {
    setCookie(res,"ibelsa_sid","ok",{ secure:false });
    return res.redirect(302,"/ibelsa.html");
  }
  res.status(401).sendFile(sendFile("login.html"));
});

